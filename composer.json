{
    "name": "fain182/ext-imap-polyfill",
    "description": "Drop-in polyfill for the imap_* functions removed from PHP core in 8.4, built on webklex/php-imap",
    "type": "library",
    "license": "MIT",
    "keywords": ["imap", "polyfill", "ext-imap", "compatibility", "mail"],
    "require": {
        "php": "^8.1",
        "webklex/php-imap": "^6.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "provide": {
        "ext-imap": "*"
    },
    "autoload": {
        "psr-4": {
            "Fain182\\ImapPolyfill\\": "src/"
        },
        "classmap": [
            "src/Connection.php"
        ],
        "files": [
            "bootstrap.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Fain182\\ImapPolyfill\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
